# SORTEIO :
import random
def f_sortei():
    '''sorteio do local e situação'''
    'porta' == False
    'cozinha' == False
    'sala' == False
    'quarto1' == False
    'quarto2' == False

    dados = []
    local = ['porta','sala','cozinha','quarto1','quarto2']
    estado = [True, False, True, True]

    sorte_local= random.choice(local)
    sorte_estado = random.choice(estado)
    
    dados.append(sorte_local)
    dados.append(sorte_estado)

    return dados

# MOSTRADOR : 
def f_mostrador(v_conta_geral):
    '''mostra o nível do perigo usando barras'''
    print('perigo : ', end='')
    for a in range(v_conta_geral):
        print('▓ ', end='')

